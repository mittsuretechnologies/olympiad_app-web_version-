generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model School {
  id            String                 @id @default(uuid())
  schoolId      String                 @unique
  olympiadId    String
  name          String
  address       String?
  email         String?
  phone         String?
  contactPerson String?
  city          String?
  district      String?
  state         String?
  pincode       String?
  username      String?                @unique
  password      String?
  plainPassword String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  olympiadIds   OlympiadIdAllocation[]
}

model Uploader {
  id         String   @id @default(uuid())
  uploaderId String   @unique
  name       String
  email      String?
  phone      String?
  username   String   @unique
  password   String
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OlympiadIdAllocation {
  id        String    @id @default(uuid())
  code      String    @unique
  prefix    String
  sequence  Int
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId  String
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  student   Student?

  @@index([schoolId])
}

model Student {
  id            String               @id @default(uuid())
  olympiadCode  String               @unique
  allocation    OlympiadIdAllocation @relation(fields: [olympiadCode], references: [code], onDelete: Cascade)
  name          String
  phone         String
  password      String?
  plainPassword String?
  isVerified    Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  videos        Video[]
}

model Video {
  id              String   @id @default(uuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  videoUrl        String
  thumbnailUrl    String?
  caption         String?
  category        String?
  subCategory     String?
  tags            String?  // Stored as comma separated or JSON string depending on DB
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([studentId])
  @@index([status])
}

model Viewer {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
