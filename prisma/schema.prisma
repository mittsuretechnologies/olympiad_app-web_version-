generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model School {
  id            String                 @id @default(uuid())
  schoolId      String                 @unique
  olympiadId    String
  name          String
  address       String?
  email         String?
  phone         String?
  contactPerson String?
  city          String?
  state         String?
  pincode       String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  password      String?
  username      String?                @unique
  plainPassword String?
  district      String?
  isActive      Boolean                @default(true)
  olympiadIds   OlympiadIdAllocation[]

  @@schema("public")
}

model Uploader {
  id            String   @id @default(uuid())
  uploaderId    String   @unique
  name          String
  email         String?
  phone         String?
  username      String   @unique
  password      String
  plainPassword String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@schema("public")
}

model OlympiadIdAllocation {
  id           String    @id @default(uuid())
  code         String    @unique
  prefix       String
  sequence     Int
  classCode    String?
  className    String?
  schoolId     String
  createdAt    DateTime  @default(now())
  sentAt       DateTime?
  assignedName String?
  assignedAt   DateTime?
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student?

  @@index([schoolId])
  @@schema("public")
}

model Student {
  id            String               @id @default(uuid())
  olympiadCode  String               @unique
  name          String
  phone         String
  password      String?
  username      String?              @unique
  isVerified    Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  plainPassword String?
  allocation    OlympiadIdAllocation @relation(fields: [olympiadCode], references: [code], onDelete: Cascade)
  videos        Video[]

  @@schema("public")
}

model Video {
  id              String           @id @default(uuid())
  studentId       String?
  appUserId       String?
  uploaderType    String           @default("STUDENT")
  videoUrl        String
  thumbnailUrl    String?
  caption         String?
  category        String?
  subCategory     String?
  tags            String?
  status          String           @default("PENDING")
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isEvaluation    Boolean          @default(false)
  isPublic        Boolean          @default(true)
  olympiadVisibility String?       // "public" | "private" — only meaningful when isEvaluation = true
  likesCount      Int              @default(0)
  viewsCount      Int              @default(0)
  deletedAt       DateTime?
  student         Student?         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  likes           Like[]
  views           VideoView[]
  reelShares      ReelShare[]
  evaluation      VideoEvaluation?
  reports         VideoReport[]

  @@index([studentId])
  @@index([appUserId])
  @@index([status])
  @@index([status, isPublic])
  @@index([deletedAt])
  @@schema("public")
}

model VideoEvaluation {
  id                String          @id @default(uuid())
  videoId           String          @unique
  evaluatorId       String
  confidenceScore   Int
  creativityScore   Int
  techniqueScore    Int
  presentationScore Int
  totalScore        Int
  remarks           String?
  isPublished       Boolean         @default(false)
  publishedAt       DateTime?
  lastEditedBy      String?
  lastEditedAt      DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  video             Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  evaluator         TalentEvaluator @relation(fields: [evaluatorId], references: [id], onDelete: Restrict)

  @@index([evaluatorId])
  @@schema("public")
}

model Viewer {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model Reviewer {
  id                   String                 @id @default(uuid())
  reviewerId           String                 @unique
  name                 String
  email                String                 @unique
  password             String
  plainPassword        String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  individualPermission IndividualPermissions?

  @@schema("public")
}

model TalentEvaluator {
  id                   String                 @id @default(uuid())
  evaluatorId          String                 @unique
  name                 String
  email                String                 @unique
  password             String
  plainPassword        String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  individualPermission IndividualPermissions?
  evaluations          VideoEvaluation[]

  @@schema("public")
}

model RolePermissions {
  id             String   @id @default(uuid())
  role           String   @unique
  allowedModules String[]
  updatedAt      DateTime @updatedAt

  @@schema("public")
}

model IndividualPermissions {
  id             String           @id @default(uuid())
  memberId       String           @unique
  role           String
  allowedModules String[]
  reviewerId     String?          @unique
  evaluatorId    String?          @unique
  updatedAt      DateTime         @updatedAt
  reviewer       Reviewer?        @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  evaluator      TalentEvaluator? @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model Like {
  id        String   @id @default(uuid())
  videoId   String
  userId    String
  userType  String
  createdAt DateTime @default(now())
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@index([videoId])
  @@schema("public")
}

model VideoView {
  id        String   @id @default(uuid())
  videoId   String
  sessionId String
  createdAt DateTime @default(now())
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([videoId, sessionId])
  @@schema("public")
}

model AppUser {
  id                     String          @id @default(uuid())
  userId                 String          @unique
  email                  String?         @unique
  mobile                 String?         @unique
  avatarUrl              String?
  password               String
  plainPassword          String?
  termsAccepted          Boolean         @default(false)
  otpHash                String?
  otpExpiresAt           DateTime?
  isVerified             Boolean         @default(false)
  olympiadId             String?
  isPrivate              Boolean         @default(false)
  olympiadCatAApproved   Boolean         @default(false)
  olympiadCatBApproved   Boolean         @default(false)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  followers              Follow[]        @relation("UserFollowers")
  following              Follow[]        @relation("UserFollowing")
  followRequestsSent     FollowRequest[] @relation("FollowRequestSender")
  followRequestsReceived FollowRequest[] @relation("FollowRequestReceiver")
  reelSharesSent         ReelShare[]     @relation("ReelShareSender")
  reelSharesReceived     ReelShare[]     @relation("ReelShareRecipient")
  reportsSubmitted       VideoReport[]
  supportTickets         SupportTicket[]

  @@index([email])
  @@index([mobile])
  @@schema("public")
}

model AppOtp {
  id         String   @id @default(uuid())
  identifier String   @unique
  otpHash    String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@schema("public")
}

model PasswordResetOtp {
  id         String   @id @default(uuid())
  identifier String   @unique
  otpHash    String
  attempts   Int      @default(0)
  lastSentAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@schema("public")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    AppUser  @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   AppUser  @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@schema("public")
}

model FollowRequest {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sender     AppUser  @relation("FollowRequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   AppUser  @relation("FollowRequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@schema("public")
}

model ReelShare {
  id          String    @id @default(uuid())
  videoId     String
  senderId    String
  recipientId String
  sentAt      DateTime  @default(now())
  readAt      DateTime?
  video       Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  sender      AppUser   @relation("ReelShareSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   AppUser   @relation("ReelShareRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([senderId, recipientId])
  @@index([videoId])
  @@schema("public")
}

model VideoReport {
  id           String   @id @default(uuid())
  videoId      String
  reporterId   String
  ownerId      String?
  category     String   // ABUSIVE_CONTENT | SPAM | HARASSMENT | HATE_SPEECH | VIOLENCE | SEXUAL_CONTENT | MISINFORMATION | COPYRIGHT | OTHER
  customReason String?
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  reporter     AppUser  @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([videoId, reporterId])
  @@index([videoId])
  @@index([reporterId])
  @@schema("public")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model SupportTicket {
  id             String   @id @default(uuid())
  userId         String
  category       String?  // Account Issue | Video Upload | Payment | Bug Report | Other
  message        String
  screenshotUrls String?  // comma-separated URLs, up to 3
  status         String   @default("OPEN") // OPEN | RESOLVED
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@schema("public")
}
