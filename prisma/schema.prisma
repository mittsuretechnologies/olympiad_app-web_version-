generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model School {
  id            String                 @id @default(uuid())
  schoolId      String                 @unique
  olympiadId    String
  name          String
  address       String?
  email         String?
  phone         String?
  contactPerson String?
  city          String?
  state         String?
  pincode       String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  password      String?
  username      String?                @unique
  plainPassword String?
  district      String?
  olympiadIds   OlympiadIdAllocation[]
}

model Uploader {
  id         String   @id @default(uuid())
  uploaderId String   @unique
  name       String
  email      String?
  phone      String?
  username   String   @unique
  password   String
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OlympiadIdAllocation {
  id        String    @id @default(uuid())
  code      String    @unique
  prefix    String
  sequence  Int
  schoolId  String
  createdAt DateTime  @default(now())
  sentAt    DateTime?
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student?

  @@index([schoolId])
}

model Student {
  id            String               @id @default(uuid())
  olympiadCode  String               @unique
  name          String
  phone         String
  password      String?
  isVerified    Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  plainPassword String?
  allocation    OlympiadIdAllocation @relation(fields: [olympiadCode], references: [code], onDelete: Cascade)
  videos        Video[]
}

model Video {
  id              String      @id @default(uuid())
  studentId       String?
  appUserId       String?
  uploaderType    String      @default("STUDENT")  // "STUDENT" | "VIEWER"
  videoUrl        String
  thumbnailUrl    String?
  caption         String?
  category        String?
  subCategory     String?
  tags            String?
  status          String      @default("PENDING")
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isEvaluation    Boolean     @default(false)
  isPublic        Boolean     @default(true)
  likesCount      Int         @default(0)
  viewsCount      Int         @default(0)
  student         Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  likes           Like[]
  views           VideoView[]

  @@index([studentId])
  @@index([appUserId])
  @@index([status])
  @@index([status, isPublic])
}

model Viewer {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id        String   @id @default(uuid())
  videoId   String
  userId    String
  userType  String   // "student", "viewer", "anonymous"
  createdAt DateTime @default(now())
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, userId])
  @@index([videoId])
}

model VideoView {
  id        String   @id @default(uuid())
  videoId   String
  sessionId String
  createdAt DateTime @default(now())
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([videoId, sessionId])
}

model AppUser {
  id             String    @id @default(uuid())
  userId         String    @unique
  email          String?   @unique
  mobile         String?   @unique
  password       String
  plainPassword  String?
  termsAccepted  Boolean   @default(false)
  otpHash        String?
  otpExpiresAt   DateTime?
  isVerified     Boolean   @default(false)
  olympiadId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([email])
  @@index([mobile])
}

model AppOtp {
  id         String   @id @default(uuid())
  identifier String   @unique
  otpHash    String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}
