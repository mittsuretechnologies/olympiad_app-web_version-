# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# user-uploaded runtime content (avatars, videos) — NOT source code.
# These are generated at runtime, may contain user PII, and bloat the repo. Served from
# disk/S3 in deployment, never committed.
/public/uploads/

# stray dev artifacts / screenshots accidentally dropped in public/ — not real assets
/public/naya.png
/public/ChatGPT Image*.png
